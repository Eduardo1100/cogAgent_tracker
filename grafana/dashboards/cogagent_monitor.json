      "title": "Success Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cogagent-pg"
          },
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(\n  ROUND(AVG(success::int::float8)::numeric, 4),\n  0\n) AS success_rate\nFROM episode_runs\nWHERE experiment_id = ${experiment_id}",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "cogagent-pg"
