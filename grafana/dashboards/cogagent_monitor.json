      "title": "Total Cost",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cogagent-pg"
          },
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(\n  ROUND(\n    COALESCE(\n      NULLIF(e.total_cost, 0),\n      ep.total_cost,\n      0\n    )::numeric,\n    4\n  ),\n  0\n) AS total_cost\nFROM experiment_runs e\nLEFT JOIN LATERAL (\n  SELECT SUM(COALESCE(episode_cost, 0)) AS total_cost\n  FROM episode_runs\n  WHERE experiment_id = e.id\n) ep ON TRUE\nWHERE e.id = ${experiment_id}",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "cogagent-pg"
      },
