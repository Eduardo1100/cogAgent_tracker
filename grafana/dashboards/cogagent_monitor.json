          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(\n  COALESCE(\n    NULLIF(e.total_tokens, 0),\n    ep.total_tokens,\n    0\n  ),\n  0\n) AS total_tokens_so_far\nFROM experiment_runs e\nLEFT JOIN LATERAL (\n  SELECT SUM(COALESCE(prompt_tokens, 0) + COALESCE(completion_tokens, 0)) AS total_tokens\n  FROM episode_runs\n  WHERE experiment_id = e.id\n) ep ON TRUE\nWHERE e.id = ${experiment_id}",
          "format": "table",
          "refId": "A"
        }
      ]
    },
