      "title": "Current Game",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cogagent-pg"
          },
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(\n  NULLIF(e.current_game_label, ''),\n  CASE\n    WHEN last_ep.game_number IS NOT NULL THEN\n      CASE\n        WHEN COALESCE(e.status, CASE WHEN e.end_time IS NULL THEN 'RUNNING' ELSE 'CONCLUDED' END) = 'RUNNING'\n          THEN 'Game #' || last_ep.game_number || ' (running)'\n        WHEN COALESCE(e.status, CASE WHEN e.end_time IS NULL THEN 'RUNNING' ELSE 'CONCLUDED' END) = 'CANCELLED'\n          THEN 'Game #' || last_ep.game_number || ' (cancelled)'\n        ELSE 'Game #' || last_ep.game_number || ' (completed)'\n      END\n    WHEN COALESCE(e.status, CASE WHEN e.end_time IS NULL THEN 'RUNNING' ELSE 'CONCLUDED' END) = 'RUNNING' THEN 'starting'\n    WHEN COALESCE(e.status, CASE WHEN e.end_time IS NULL THEN 'RUNNING' ELSE 'CONCLUDED' END) = 'CANCELLED' THEN 'cancelled before first game'\n    ELSE 'no episodes recorded'\n  END\n) AS current_game\nFROM experiment_runs e\nLEFT JOIN LATERAL (\n  SELECT game_number\n  FROM episode_runs\n  WHERE experiment_id = e.id\n  ORDER BY game_number DESC\n  LIMIT 1\n) last_ep ON TRUE\nWHERE e.id = ${experiment_id}",
          "format": "table",
          "refId": "A"
        }
      ]
    },
