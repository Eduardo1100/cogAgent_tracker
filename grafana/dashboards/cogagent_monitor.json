          },
          "editorMode": "code",
          "rawQuery": true,
          "rawSql": "SELECT CASE\n  WHEN NULLIF(git_branch, '') IS NULL AND NULLIF(git_commit, '') IS NULL THEN 'not set'\n  WHEN NULLIF(git_branch, '') IS NULL THEN LEFT(git_commit, 7)\n  WHEN NULLIF(git_commit, '') IS NULL THEN git_branch\n  ELSE git_branch || ' @ ' || LEFT(git_commit, 7)\nEND AS git_ref\nFROM experiment_runs\nWHERE id = ${experiment_id}",
