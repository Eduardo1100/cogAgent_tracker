# Copy this file to `.env` and replace placeholder values with real secrets.
# Do not commit your populated `.env`.

# PostgreSQL
POSTGRES_USER=devuser
POSTGRES_PASSWORD=devpass
POSTGRES_DB=devdb

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=miniouser
MINIO_ROOT_PASSWORD=miniopass

# Local app service URLs
DATABASE_URL=postgresql+psycopg2://devuser:devpass@localhost:5432/devdb
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=miniouser
S3_SECRET_KEY=miniopass

# Model provider keys
DEEPSEEK_API_KEY=replace-me
GEMINI_API_KEY=replace-me
OPENAI_API_KEY=replace-me
ANTHROPIC_API_KEY=replace-me

# Optional model/runtime settings
ACTIVE_LLM_PROFILE=gemini_with_deepseek_reasoner
CACHE_SEED=42
LOCAL_API_BASE=http://localhost:11434/v1
HF_TOKEN=replace-me

# Optional experiment tooling
WANDB_API_KEY=
WANDB_MODE=online

# Optional WebArena / BrowserGym instance URLs
# If you run `make debug ENV=webarena` through Docker and the WebArena sites run on
# your host machine, use `http://host.docker.internal:<port>` rather than localhost.
WA_SHOPPING=
WA_SHOPPING_ADMIN=
WA_REDDIT=
WA_GITLAB=
WA_WIKIPEDIA=
WA_MAP=
WA_HOMEPAGE=
WA_FULL_RESET=
PW_EXTRA_HEADERS=
WEBARENA_REPO_URL=https://github.com/web-arena-x/webarena.git
WEBARENA_REPO_REV=dce04686a56253aefba7b18a4fa0937cf1dc987b
WEBARENA_REPO_DIR=.cache/webarena-src

# Optional AndroidWorld settings
ANDROIDWORLD_REPO_URL=https://github.com/google-research/android_world.git
ANDROIDWORLD_REPO_REF=d9c569f764b3a5629321858de03ff653d0f24056
ANDROIDWORLD_REPO_DIR=.cache/android_world-src
ANDROIDWORLD_ADB_PATH=
ANDROIDWORLD_ADB_INSTALL_TIMEOUT=600

# Optional debugging
# Set to 1 only if you intentionally need to bypass the Alembic revision check.
SKIP_SCHEMA_REVISION_CHECK=0
