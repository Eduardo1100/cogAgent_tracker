# Database Credentials
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_db

# MinIO (S3) Credentials
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@localhost:5432/your_postgres_db

# LLM Profile Selection (see all preset option in configs or make your own)
ACTIVE_LLM_PROFILE="deepseek_full_stack"

# API Keys
OPENAI_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""
WANDB_API_KEY=""
HF_TOKEN=""

# Base URLs (Optional, for Local LLMs like Ollama/vLLM)
LOCAL_API_BASE="http://localhost:11434/v1"

# User/Group IDs (match your host user to avoid permission issues)
UID=1000
GID=1000
